# --- LLM ---
# Set to your OpenAI key to use GPT models.
# Leave empty or "disabled" to fall back to local Ollama instead.
OPENAI_API_KEY=disabled

# Model to use when OPENAI_API_KEY is set. Default: gpt-4.1-mini
# LLM_MODEL=gpt-4.1-mini

# Ollama settings (only used when OPENAI_API_KEY is empty / disabled)
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# --- Reranker (optional, adds ~2.5 GB to Docker image) ---
# Default: off. Reranker is disabled unless you explicitly opt in.
# To enable: set both vars, then rebuild with `docker compose up --build`.
# INSTALL_RERANKER=true    # installs sentence-transformers into the image
# DISABLE_RERANKER=        # leave empty to enable reranker at runtime

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Auth ---
# Optional: set to restrict access. Leave empty or "disabled" for local dev.
API_KEY=disabled

# --- CORS ---
# Optional: comma-separated allowed origins. Defaults to * (all origins).
# ALLOWED_ORIGINS=http://localhost:3000
